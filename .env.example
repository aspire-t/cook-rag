# CookRAG 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql+asyncpg://cookrag:cookrag_password@localhost:5432/cookrag

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Qdrant 配置 ====================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=recipes

# ==================== Elasticsearch 配置 ====================
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=recipes

# ==================== LLM 配置（阿里云百炼）====================
DASHSCOPE_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-plus

# ==================== 图片存储配置 ====================
IMAGE_REPO_OWNER=aspire-t
IMAGE_REPO_NAME=cook-rag-images
IMAGE_BASE_CDN_URL=https://cdn.jsdelivr.net/gh/aspire-t/cook-rag-images@main/
GITHUB_TOKEN=ghp_your_github_token_here

# ==================== CLIP 模型配置 ====================
# 设备选择：mps (Mac) / cuda (NVIDIA GPU) / cpu
CLIP_MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
CLIP_DEVICE=mps

# ==================== JWT 配置 ====================
# 生产环境请使用强随机密钥！
SECRET_KEY=your-super-secret-key-change-in-production

# ==================== 微信小程序配置 ====================
WECHAT_APPID=wx_your_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ==================== 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
ENV=development
